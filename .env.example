# Notion integration token (get from https://www.notion.so/my-integrations)
NOTION_TOKEN=ntn_xxxxxxxxxxxx

# Azure OpenAI — key is fetched dynamically via `az` CLI (no secret stored here)
# Just provide the resource identifiers:
AZURE_OPENAI_RESOURCE_GROUP=rg-macedonian-vocab
AZURE_OPENAI_ACCOUNT_NAME=mk-vocab-openai
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
